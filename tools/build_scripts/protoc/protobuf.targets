<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<ItemGroup>
		<PropertyPageSchema
			Include="$(MSBuildThisFileDirectory)$(MSBuildThisFileName).xml" />
		<AvailableItemName
			Include="ProtocolBuffer">
			<Targets>_ProtocolBuffer</Targets>
		</AvailableItemName>
	</ItemGroup>
	<UsingTask
		TaskName="ProtocolBuffer"
		TaskFactory="XamlTaskFactory"
		AssemblyName="Microsoft.Build.Tasks.v4.0">
		<Task>$(MSBuildThisFileDirectory)$(MSBuildThisFileName).xml</Task>
	</UsingTask>
	<!--
		LEGACY PROTOBUF GENERATION — INTENTIONALLY DISABLED.

		This target ran protoc (from contrib/vcpkg/installed, currently 6.33.4) and
		wrote .pb.cc/.pb.h next to the .proto sources (see protobuf.props: --cpp_out
		into the source directory). Those files shadowed the headers generated by the
		modern CMake/preset build (protobuf_generate -> build/, protobuf 3.21.12),
		producing 'google/protobuf/runtime_version.h' C1083 errors.

		The build is now preset/CMake-only (cmake --preset live). Protobuf code is
		generated by protobuf_generate() into the build tree, never the source tree.
		The 'Condition="false"' below disables this legacy step entirely so the old
		MSBuild solution path can no longer reintroduce stale generated files. The
		modern build does not import this file and is unaffected. To restore the
		legacy MSBuild generation, change the condition back to "'@(ProtocolBuffer)' != ''".
	-->
	<Target
		Name="_ProtocolBuffer"
		BeforeTargets="$(ProtocolBufferBeforeTargets)"
		AfterTargets="$(ProtocolBufferAfterTargets)"
		Condition="false"
		DependsOnTargets="$(ProtocolBufferDependsOn);ComputeProtocolBufferOutput"
		Outputs="%(ProtocolBuffer.Outputs)"
		Inputs="%(ProtocolBuffer.Identity);%(ProtocolBuffer.AdditionalDependencies);$(ProtocPath);$(MSBuildProjectFile)">
		<ItemGroup
			Condition="'@(SelectedFiles)' != ''">
			<ProtocolBuffer
				Remove="@(ProtocolBuffer)"
				Condition="'%(Identity)' != '@(SelectedFiles)'" />
		</ItemGroup>
		<ItemGroup>
			<ProtocolBufferFilesToDelete Include="%(ProtocolBuffer.Outputs)" />
		</ItemGroup>
		<Message
			Importance="High"
			Text="%(ProtocolBuffer.ExecutionDescription)" />
		<ProtocolBuffer
			Condition="'@(ProtocolBuffer)' != '' and '%(ProtocolBuffer.ExcludedFromBuild)' != 'true'"
			CommandLineTemplate="%(ProtocolBuffer.CommandLineTemplate)"
			AdditionalOptions="%(ProtocolBuffer.AdditionalOptions)"
			StandardOutputImportance="High"
			StandardErrorImportance="High"
			EchoOff="true"
			Inputs="%(ProtocolBuffer.Identity)" />
	</Target>
	<PropertyGroup>
		<ComputeLinkInputsTargets>
			$(ComputeLinkInputsTargets);
			ComputeProtocolBufferOutput;
		</ComputeLinkInputsTargets>
		<ComputeLibInputsTargets>
			$(ComputeLibInputsTargets);
			ComputeProtocolBufferOutput;
		</ComputeLibInputsTargets>
	</PropertyGroup>
	<Target
		Name="ComputeProtocolBufferOutput"
		Condition="'@(ProtocolBuffer)' != ''">
		<ItemGroup>
			<ProtocolBufferDirsToMake
				Condition="'@(ProtocolBuffer)' != '' and '%(ProtocolBuffer.ExcludedFromBuild)' != 'true'"
				Include="%(ProtocolBuffer.Outputs)" />
			<Link
				Include="%(ProtocolBufferDirsToMake.Identity)"
				Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
			<Lib
				Include="%(ProtocolBufferDirsToMake.Identity)"
				Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
			<ImpLib
				Include="%(ProtocolBufferDirsToMake.Identity)"
				Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
		</ItemGroup>
		<MakeDir
			Directories="@(ProtocolBufferDirsToMake-&gt;'%(RootDir)%(Directory)')" />
	</Target>
	<Target Name="_CleanProtocolBufferOutput" BeforeTargets="Clean" Condition="'@(ProtocolBuffer)' != ''">
		<Delete Files="@(ProtocolBufferFilesToDelete)" TreatErrorsAsWarnings="true" />
	</Target>
</Project>
